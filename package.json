{
  "name": "voice-sales-log",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run bot:dev\" \"npm run web:dev\"",
    "bot:dev": "npm --workspace apps/bot run dev",
    "web:dev": "npm --workspace apps/web run dev",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.1.9"
  }
}
